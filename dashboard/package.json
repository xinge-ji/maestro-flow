{
  "name": "maestro-dashboard",
  "version": "0.1.0",
  "description": "Linear-style kanban board dashboard for Maestro",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently \"vite\" \"tsx --watch src/server/index.ts\"",
    "build": "vite build && tsc -p tsconfig.node.json",
    "preview": "vite preview",
    "server": "tsx src/server/index.ts",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.77",
    "@hono/node-server": "^1.14.0",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "chokidar": "^4.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.36.0",
    "hono": "^4.7.0",
    "lucide-react": "^0.577.0",
    "maestro-flow": "file:..",
    "node-cron": "^4.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.0",
    "react-router-dom": "^6.30.3",
    "react-virtuoso": "^4.18.4",
    "remark-gfm": "^4.0.0",
    "tailwind-merge": "^3.5.0",
    "ws": "^8.19.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/node": "^22.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^4.1.0",
    "concurrently": "^9.1.0",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.0"
  }
}
