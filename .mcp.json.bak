{
  "mcpServers": {
    "maestro": {
      "command": "node",
      "args": ["bin/maestro-mcp.js"],
      "env": {
        "MAESTRO_ENABLED_TOOLS": "write_file,edit_file,read_file,read_many_files,team_msg,store_knowhow"
      }
    },
    "claude_dms3-chrome-devtools": {
      "command": "npx",
      "args": [
        "chrome-devtools-mcp@latest"
      ]
    },
    "exa": {
      "url": "https://mcp.exa.ai/mcp",
      "type": "http"
    }
  }
}
