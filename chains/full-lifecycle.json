{
  "$schema": "./chain-graph.schema.json",
  "id": "full-lifecycle",
  "name": "Full Lifecycle",
  "description": "Plan -> Execute -> Verify -> Review -> Test -> Milestone Audit/Complete with decision points",
  "version": "2.0.0",
  "tags": ["lifecycle", "milestone"],
  "entry": "plan",
  "inputs": {
    "phase": { "type": "string", "required": false },
    "description": { "type": "string" }
  },
  "defaults": { "analyze": true },
  "nodes": {
    "plan": {
      "type": "command",
      "cmd": "maestro-plan",
      "description": "Create execution plan by exploring codebase, clarifying requirements, and generating task decomposition",
      "args": "{phase}",
      "auto_flag": "--auto",
      "next": "execute"
    },
    "execute": {
      "type": "command",
      "cmd": "maestro-execute",
      "description": "Run wave-based parallel task execution with atomic commits",
      "args": "{phase}",
      "next": "verify"
    },
    "verify": {
      "type": "command",
      "cmd": "maestro-verify",
      "description": "Goal-backward 3-layer verification with anti-pattern scan",
      "args": "{phase}",
      "next": "check_verify",
      "max_visits": 3
    },
    "check_verify": {
      "type": "decision",
      "eval": "ctx.result.verification_status",
      "edges": [
        { "value": "passed", "target": "review" },
        { "default": true, "target": "fix_plan" }
      ]
    },
    "fix_plan": {
      "type": "command",
      "cmd": "maestro-plan",
      "description": "Re-plan to address verification gaps and failures",
      "args": "{phase} --gaps",
      "auto_flag": "--auto",
      "next": "fix_execute"
    },
    "fix_execute": {
      "type": "command",
      "cmd": "maestro-execute",
      "description": "Re-execute tasks from updated gap-fix plan",
      "args": "{phase}",
      "next": "verify",
      "max_visits": 3
    },
    "review": {
      "type": "command",
      "cmd": "quality-review",
      "description": "Multi-dimensional code review with severity classification",
      "args": "{phase}",
      "next": "check_review"
    },
    "check_review": {
      "type": "decision",
      "eval": "ctx.result.review_verdict",
      "edges": [
        { "value": "BLOCK", "target": "fix_plan" },
        { "default": true, "target": "test" }
      ]
    },
    "test": {
      "type": "command",
      "cmd": "quality-test",
      "description": "User acceptance testing with auto-diagnosis",
      "args": "{phase}",
      "auto_flag": "--auto-fix",
      "next": "check_test"
    },
    "check_test": {
      "type": "decision",
      "eval": "ctx.result.uat_status",
      "edges": [
        { "value": "passed", "target": "milestone_audit" },
        { "default": true, "target": "debug" }
      ]
    },
    "debug": {
      "type": "command",
      "cmd": "quality-debug",
      "description": "Hypothesis-driven debugging from UAT failures",
      "args": "--from-uat {phase}",
      "next": "fix_execute",
      "max_visits": 2
    },
    "milestone_audit": {
      "type": "command",
      "cmd": "maestro-milestone-audit",
      "description": "Audit milestone for cross-phase integration gaps using artifact registry",
      "next": "check_audit"
    },
    "check_audit": {
      "type": "decision",
      "eval": "ctx.result.audit_verdict",
      "edges": [
        { "value": "PASS", "target": "milestone_complete" },
        { "default": true, "target": "fix_plan" }
      ]
    },
    "milestone_complete": {
      "type": "command",
      "cmd": "maestro-milestone-complete",
      "description": "Archive scratch artifacts, move to milestone_history, advance to next milestone",
      "next": "done"
    },
    "done": {
      "type": "terminal",
      "status": "success"
    }
  }
}
