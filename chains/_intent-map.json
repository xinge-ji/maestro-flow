{
  "$schema": "intent-map.schema.json",
  "version": "1.0.0",
  "patterns": [
    {
      "type": "state_continue",
      "regex": "^(continue|next|go|继续|下一步)$",
      "flags": "i",
      "route": { "strategy": "state_router" }
    },
    {
      "type": "status",
      "regex": "^(status|状态|dashboard)$",
      "flags": "i",
      "route": { "graph": "singles/status" }
    },
    {
      "type": "spec_generate",
      "regex": "spec.*(generat|creat|build)|PRD|产品.*规格",
      "flags": "i",
      "route": { "graph": "spec-driven" }
    },
    {
      "type": "brainstorm",
      "regex": "brainstorm|ideate|头脑风暴|发散",
      "flags": "i",
      "route": { "graph": "brainstorm-driven" }
    },
    {
      "type": "discuss",
      "regex": "discuss|discussion|grill|聊聊|先问清楚|想清楚再说|讨论一下",
      "flags": "i",
      "route": { "graph": "discuss-driven" }
    },
    {
      "type": "analyze",
      "regex": "analy[sz]e|feasib|evaluat|assess|分析|评估|讨论",
      "flags": "i",
      "route": { "graph": "singles/analyze" }
    },
    {
      "type": "ui_design",
      "regex": "ui.*design|design.*ui|prototype|设计.*原型|UI.*风格",
      "flags": "i",
      "route": { "graph": "ui-design-driven" }
    },
    {
      "type": "init",
      "regex": "init|setup.*project|初始化|新项目",
      "flags": "i",
      "route": { "graph": "singles/init" }
    },
    {
      "type": "plan",
      "regex": "plan(?!.*gap)|break.*down|规划|分解",
      "flags": "i",
      "route": { "graph": "singles/plan" }
    },
    {
      "type": "roadmap",
      "regex": "roadmap|路线图",
      "flags": "i",
      "route": { "graph": "roadmap-driven" }
    },
    {
      "type": "execute",
      "regex": "execute|implement|build|develop|code|实现|开发",
      "flags": "i",
      "route": { "graph": "singles/execute" }
    },
    {
      "type": "verify",
      "regex": "verif[iy]|validate.*result|验证|校验",
