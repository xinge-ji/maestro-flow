      "route": { "graph": "singles/spec-setup" }
    },
    {
      "type": "spec_add",
      "regex": "spec.*add|添加.*规范",
      "flags": "i",
      "route": { "graph": "singles/spec-add" }
    },
    {
      "type": "spec_load",
      "regex": "spec.*load|加载.*规范",
      "flags": "i",
      "route": { "graph": "singles/spec-load" }
    },
    {
