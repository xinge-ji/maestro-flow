      "flags": "i",
      "route": { "graph": "singles/issue-plan" }
    },
    {
      "type": "issue_execute",
      "regex": "execute.*issue|run.*issue",
      "flags": "i",
      "route": { "graph": "singles/issue-execute" }
    },
    {
      "type": "issue_discover",
      "regex": "discover.*issue|find.*issue|发现.*问题",
      "flags": "i",
      "route": { "graph": "singles/issue-discover" }
    },
    {
      "type": "issue",
      "regex": "issue|问题|缺陷",
      "flags": "i",
      "route": { "graph": "singles/issue" }
    },
    {
      "type": "codebase_rebuild",
      "regex": "codebase.*rebuild|重建.*文档",
      "flags": "i",
      "route": { "graph": "singles/codebase-rebuild" }
    },
    {
      "type": "codebase_refresh",
      "regex": "codebase.*refresh|刷新.*文档",
      "flags": "i",
      "route": { "graph": "singles/codebase-refresh" }
