      "regex": "team.*lifecycle|团队.*生命周期",
      "flags": "i",
      "route": { "graph": "singles/team-lifecycle" }
    },
    {
      "type": "team_coordinate",
      "regex": "team.*coordinat|团队.*协调",
      "flags": "i",
      "route": { "graph": "singles/team-coordinate" }
    },
    {
      "type": "team_qa",
      "regex": "team.*(qa|quality)|团队.*质量",
      "flags": "i",
      "route": { "graph": "singles/team-qa" }
