    {
      "type": "review",
      "regex": "\\breview.*code|code.*review|代码.*审查",
      "flags": "i",
      "route": { "graph": "singles/review" }
    },
    {
      "type": "test_gen",
      "regex": "test.*gen|generat.*test|add.*test|写测试",
      "flags": "i",
      "route": { "graph": "singles/test-gen" }
    },
    {
      "type": "test",
      "regex": "\\btest|uat|测试|验收",
      "flags": "i",
      "route": { "graph": "singles/test" }
    },
    {
      "type": "debug",
      "regex": "debug|diagnos|troubleshoot|fix.*bug|调试|排查",
      "flags": "i",
      "route": { "graph": "singles/debug" }
    },
    {
      "type": "business_test",
      "regex": "business.*test|PRD.*test|requirement.*test|业务.*测试|需求.*验证",
