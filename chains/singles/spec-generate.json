{
  "$schema": "../chain-graph.schema.json",
  "id": "singles/roadmap-full",
  "name": "Spec Generate",
  "description": "Generate specification package through 7-phase document chain",
  "version": "1.0.0",
  "tags": [
    "maestro",
    "spec"
  ],
  "entry": "spec_generate",
  "inputs": {
    "description": {
      "type": "string"
    }
  },
  "nodes": {
    "spec_generate": {
      "type": "command",
      "cmd": "maestro-roadmap",
      "next": "done",
      "analyze": false,
      "args": "--mode full \"{description}\"",
      "description": "Generate specification package through 7-phase document chain"
    },
    "done": {
      "type": "terminal",
      "status": "success"
    }
  }
}
