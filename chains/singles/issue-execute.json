{
  "$schema": "../chain-graph.schema.json",
  "id": "singles/issue-execute",
  "name": "Issue Execute",
  "description": "Execute planned solution for an issue via dual-mode agent dispatch",
  "version": "1.0.0",
  "tags": [
    "manage",
    "issue"
  ],
  "entry": "issue_execute",
  "inputs": {
    "description": {
      "type": "string"
    }
  },
  "nodes": {
    "issue_execute": {
      "type": "command",
      "cmd": "maestro-execute",
      "next": "done",
      "analyze": false,
      "args": "",
      "description": "Wave-based execution with automatic issue status sync"
    },
    "done": {
      "type": "terminal",
      "status": "success"
    }
  }
}
