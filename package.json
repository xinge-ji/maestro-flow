{
  "name": "maestro-flow",
  "version": "0.3.30",
  "description": "Workflow orchestration CLI with MCP endpoint support and extensible architecture",
  "type": "module",
  "imports": {
    "#maestro-dashboard/agents/*": "./dashboard/dist-server/dashboard/src/server/agents/*",
    "#maestro-dashboard/shared/*": "./dashboard/dist-server/dashboard/src/shared/*",
    "#maestro-dashboard/wiki/*": "./dashboard/dist-server/dashboard/src/server/wiki/*"
  },
  "bin": {
    "maestro": "bin/maestro.js",
    "maestro-mcp": "bin/maestro-mcp.js",
    "maestro-statusline": "bin/maestro-statusline.js",
    "maestro-context-monitor": "bin/maestro-context-monitor.js"
  },
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "bin",
    "dist",
    "shared",
    "templates",
    "workflows",
    "chains",
    ".claude/commands",
    ".claude/agents",
    ".claude/skills",
    ".claude/CLAUDE.md",
    ".codex/skills",
    "dashboard/dist",
    "dashboard/dist-server",
    "dashboard/tui/dist",
    "dashboard/package.json"
  ],
  "scripts": {
    "build": "node ./node_modules/typescript/bin/tsc -p dashboard/tsconfig.node.json && node ./node_modules/typescript/bin/tsc",
    "dev": "node ./node_modules/typescript/bin/tsc --watch",
    "start": "node bin/maestro.js",
    "mcp": "node bin/maestro-mcp.js",
    "lint": "node ./node_modules/typescript/bin/tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.77",
    "@hono/node-server": "^1.14.0",
    "@inkjs/ui": "^2.0.0",
    "@inquirer/prompts": "^8.3.2",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "argon2": "^0.44.0",
    "chokidar": "^4.0.0",
    "commander": "^13.1.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.7.0",
    "ink": "^6.0.0",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^4.0.0",
    "ink-spinner": "^5.0.0",
    "marked": "^15.0.0",
    "node-cron": "^4.2.1",
    "pg": "^8.20.0",
    "react": "^19.0.0",
    "ws": "^8.19.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.4",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  },
  "license": "MIT"
}
